{
    "name": "pseudo-fixture",
    "version": "1.1.2",
    "license": "MIT",
    "author": "Lennart Gerken",
    "description": "Contains a small helper class for creating reusable fixture structures.",
    "keywords": [
        "E2E",
        "test",
        "testautomation",
        "fixtures"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lennartgerken/pseudo-fixture.git"
    },
    "bugs": {
        "url": "https://github.com/lennartgerken/pseudo-fixture/issues"
    },
    "engines": {
        "node": ">=20.4.0"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "module": "./dist/index.js",
    "main": "./dist/index.cjs",
    "files": [
        "dist"
    ],
    "scripts": {
        "pretty": "prettier . --write",
        "pretty-check": "prettier . --check",
        "lint": "eslint .",
        "test": "vitest run",
        "build": "rollup -c"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "^25.5.2",
        "eslint": "^10.2.0",
        "prettier": "^3.8.1",
        "rollup": "^4.60.1",
        "tslib": "^2.8.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "acorn": "^8.15.0"
    }
}
